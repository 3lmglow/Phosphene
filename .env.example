# App
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
# Optional. Leave blank for first-visitor setup; set a private value to protect first-time setup.
PHOSPHENE_SETUP_TOKEN=
PHOSPHENE_TIMEZONE=Asia/Shanghai
LOG_LEVEL=info

# Default single-service mode. In production, mount one persistent volume at /data.
# SQLite and private proof images are kept below this directory.
PHOSPHENE_DATA_DIR=.data
SQLITE_PATH=
LOCAL_STORAGE_PATH=
