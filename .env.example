# App
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
PHOSPHENE_SETUP_TOKEN=change-this-before-production
PHOSPHENE_TIMEZONE=Asia/Shanghai
SESSION_SECRET=replace-with-at-least-32-random-characters
LOG_LEVEL=info

# Default single-service mode. In production, mount one persistent volume at /data.
# PGlite and private proof images are kept below this directory.
PHOSPHENE_DATA_DIR=.data
PGLITE_PATH=
LOCAL_STORAGE_PATH=

# Optional distributed mode. Setting DATABASE_URL switches the database to PostgreSQL.
DATABASE_URL=

# Use local storage in single-service mode. Set this to s3 only with a private S3/MinIO service.
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=phosphene-proofs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
