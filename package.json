{
  "name": "phosphene",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A private, self-hosted task, reward, and companionship system for one user and one AI.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server/index.ts",
    "build:web": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --target=node22 --outdir=dist/server --packages=external",
    "build": "pnpm build:web && pnpm build:server",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:deployment": "node scripts/validate-deployment.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm validate:deployment && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@electric-sql/pglite": "0.5.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "argon2": "0.41.1",
    "cookie-parser": "1.4.7",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "drizzle-orm": "0.45.2",
    "express": "5.1.0",
    "express-rate-limit": "8.6.0",
    "helmet": "8.1.0",
    "jszip": "3.10.1",
    "lucide-react": "0.536.0",
    "multer": "2.2.0",
    "nanoid": "5.1.5",
    "pg": "8.16.3",
    "pino": "9.7.0",
    "pino-http": "10.5.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "7.18.1",
    "sharp": "0.34.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@types/cookie-parser": "1.4.9",
    "@types/express": "5.0.3",
    "@types/multer": "2.2.0",
    "@types/node": "24.2.1",
    "@types/pg": "8.15.5",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "4.7.0",
    "cross-env": "10.0.0",
    "drizzle-kit": "0.31.4",
    "esbuild": "0.25.8",
    "jsdom": "26.1.0",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
    "vite": "7.1.1",
    "vitest": "3.2.4",
    "yaml": "2.8.1"
  }
}
